      "parameters": {
        "jsCode": "// Получаем входящие данные\nconst doc = $input.first().json;\n\n// Функция для поиска таблицы с 9 столбцами\nfunction findNineColumnTable(doc) {\n  const content = doc[0]?.body?.content || doc?.body?.content || [];\n  \n  for (const element of content) {\n    if (element.table && element.table.columns === 9) {\n      return element.table;\n    }\n  }\n  return null;\n}\n\nconst table = findNineColumnTable(doc);\n\nif (!table) {\n  return [{ json: { error: 'Таблица с 9 столбцами не найдена' } }];\n}\n\nconst rowCount = table.rows;\n\nif (rowCount <= 2) {\n  // Две строки и меньше — удалить весь документ\n  return [{ json: { delete: 'doc' } }];\n} else {\n  // Больше двух строк — удалить строку\n  return [{ json: { delete: 'stroke' } }];\n}"
      },
