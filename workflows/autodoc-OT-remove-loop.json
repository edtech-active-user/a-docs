         cellText += el.textRun?.content || \"\";\n        }\n      }\n      \n      // Чистим текст ячейки от любых невидимых символов\n      const cleanCell = cellText.replace(/\\s+/g, '').trim();\n      \n      if (cleanCell === cleanSearch) {\n        return {\n          found: true,\n          tableIndex,\n          rowIndex,\n          tableStartIndex: element.startIndex\n        };\n      }\n    }\n    \n    tableIndex++;\n  }\n  \n  return { found: false, searchValue, cleanSearch };\n}\n\nconst docContent = $('GetExistingVyp1').first().json.body.content;\nconst searchValue = $('InputData').first().json.data.UdRegNum;\n\nreturn [{ json: findRowInDoc(docContent, searchValue) }];\n\n"
