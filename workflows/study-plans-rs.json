    {
      "parameters": {
        "jsCode": "const jsonString = $('ПЛАН JSON').first().json.message.content;\n\n// Более агрессивная очистка строки\nlet cleanedJsonString = jsonString;\n\n// Убираем markdown блоки кода\ncleanedJsonString = cleanedJsonString.replace(/^```json\\s*\\n?/, '').replace(/```$/, '');\n// Убираем возможные префиксы\ncleanedJsonString = cleanedJsonString.replace(/^json\\s*\\n/, '');\ncleanedJsonString = cleanedJsonString.trim();\n\n// Ищем начало и конец JSON объекта\nconst startIndex = cleanedJsonString.indexOf('{');\nconst lastBraceIndex = cleanedJsonString.lastIndexOf('}');\n\nif (startIndex !== -1 && lastBraceIndex !== -1 && lastBraceIndex > startIndex) {\n    // Извлекаем только JSON объект\n    cleanedJsonString = cleanedJsonString.substring(startIndex, lastBraceIndex + 1);\n}\n\n// Дополнительная очистка от возможных невидимых символов\ncleanedJsonString = cleanedJsonString.replace(/[\\u0000-\\u001F\\u007F-\\u009F]/g, '');\n\ntry {\n    console.log('Строка для парсинга:', cleanedJsonString);\n    console.log('Длина строки:', cleanedJsonString.length);\n    \n    const parsedData = JSON.parse(cleanedJsonString);\n    console.log('Распарсенные данные:', parsedData);\n    console.log('Профессия:', parsedData[\"{Название_профессии}\"]);\n    \n    return [{ json: parsedData }];\n} catch (error) {\n    console.error('Ошибка парсинга JSON:', error);\n    console.error('Проблемная часть строки около позиции 1042:');\n    console.error(cleanedJsonString.substring(1035, 1050));\n    throw new Error(`Не удалось распарсить JSON: ${error.message}`);\n}"
      },
